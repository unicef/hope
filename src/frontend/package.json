{
  "name": "frontend",
  "version": "4.11.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build-for-backend": "bun run build --outDir '../hope/apps/web/static/web' --emptyOutDir",
    "build-and-watch": "bun run build-for-backend --watch",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "test": "vitest",
    "preview": "vite preview",
    "download-dev-openapi": "wget --no-check-certificate -O data/openapi.yml http://localhost:8080/api/rest/",
    "generate-rest-api-types": "bun run generate-rest-api-types-camelcase",
    "generate-rest-api-types-camelcase": "bun run download-dev-openapi && node enhance_and_camelize_openapi.js && bunx openapi-typescript-codegen --input data/openapi-camelcase.yml --output src/restgenerated --useOptions --postfixModels CamelCase --exportCore false",
    "prune-unused-exports": "bunx ts-prune src | grep -v '(used in module)' | grep -v '/index.'"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@date-io/moment": "^3.2.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/styled-engine-sc": "^7.3.8",
    "@mui/system": "^7.3.8",
    "@mui/x-date-pickers": "7.29.4",
    "@mui/x-tree-view": "8.27.2",
    "@sentry/react": "10.42.0",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-query-devtools": "5.91.3",
    "chart.js": "^4.5.1",
    "chartjs-plugin-annotation": "^3.1.0",
    "chartjs-plugin-datalabels": "^2.2.0",
    "clsx": "^2.1.1",
    "date-fns": "2.29.3",
    "formik": "^2.4.9",
    "i18next": "25.8.14",
    "localforage": "^1.10.0",
    "lodash": "^4.17.23",
    "moment": "^2.30.1",
    "prop-types": "^15.8.1",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-clipboard.js": "^2.0.16",
    "react-dom": "19.2.4",
    "react-dropzone": "15.0.0",
    "react-i18next": "16.5.4",
    "react-idle-timer": "^5.7.2",
    "react-router-dom": "7.13.1",
    "react-use": "^17.6.0",
    "react-zoom-pan-pinch": "^3.7.0",
    "string.prototype.replaceall": "^1.0.11",
    "styled-components": "6.3.11",
    "use-deep-compare-effect": "^1.8.1",
    "uuid": "^13.0.0",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/plugin-syntax-jsx": "^7.28.6",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/plugin-transform-object-rest-spread": "^7.28.6",
    "@babel/plugin-transform-typescript": "^7.28.6",
    "@babel/preset-env": "7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@emotion/babel-plugin": "^11.13.5",
    "@eslint/compat": "2.0.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "10.0.1",
    "@tanstack/eslint-plugin-query": "5.91.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vitejs/plugin-react": "5.1.4",
    "braces": "3.0.3",
    "camelcase": "^9.0.0",
    "cross-spawn": "^7.0.6",
    "esbuild": "0.27.3",
    "eslint": "^10.0.2",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "form-data": "^4.0.5",
    "glob": "13.0.6",
    "globals": "17.4.0",
    "helmet": "^8.1.0",
    "js-yaml": "^4.1.1",
    "jsdom": "28.1.0",
    "micromatch": "4.0.8",
    "msw": "2.12.10",
    "openapi-typescript-codegen": "^0.30.0",
    "path": "^0.12.7",
    "prettier": "3.8.1",
    "react-test-renderer": "19.2.4",
    "tough-cookie": "^6.0.0",
    "ts-node": "^10.9.2",
    "ts-prune": "^0.10.3",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-csp-guard": "3.0.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.0.18",
    "waait": "^1.0.5"
  },
  "overrides": {
    "minimatch": ">=9.0.5",
    "rollup": ">=4.59.0",
    "undici": ">=7.18.2"
  }
}
